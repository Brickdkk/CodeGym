{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2020",
    "moduleResolution": "node",
    "types": ["node", "jest"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true
  },
  "include": [
    "server/**/*",
    "server/**/*.test.ts",
    "server/**/__tests__/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "client"
  ]
}
