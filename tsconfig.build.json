{
  "extends": "./tsconfig.server.json",
  "compilerOptions": {
    "noImplicitAny": false,
    "strict": false,
    "noEmitOnError": false,
    "skipLibCheck": true,
    "suppressImplicitAnyIndexErrors": true,
    "noImplicitReturns": false,
    "noImplicitThis": false,
    "strictNullChecks": false
  }
}
