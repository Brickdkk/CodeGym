{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server" },
    { "source": "/health", "destination": "/api/server" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
